<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Password Update</title>
    <link rel="stylesheet" href="/css/style.css">
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB" crossorigin="anonymous">
  <link rel="stylesheet"
  href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css">
</head>
<body>
  <form  action="/login" method="get">
  <div class="container-fluid container mt-6 bg-white p-2 rounded-4">
    <div class="row">
      <div class="col-md-6 p3">
            <img src="/images/login-side-img.png"  alt="Login Image" class="img-fluid img">
      </div>
    <div class="col-md-6 p3">
      <!-- Login Form -->
       <div class="mt-5" style="margin-left:0.1rem;"><i class="fa-solid fa-compass fa-4x text-danger"> <b style="font-size: 2rem;font-weight: bolder;">E-S p u r t</b></i></div>
       <h1 class="heading mt-5 mb-2">Update Password</h1>
      <p class="para mb-4">Please enter your new password</p>
      <input
       type="password"
       name="new-password"
       placeholder="New password"
       class="form-control custom-input mb-4"
       required>
      <input 
        type="password"
        name="new-password"
        placeholder="Confirm password"
        class="form-control custom-input mb-1"
        required>
        <br/>
       <br/>
      <br/><br/>
      <button class="btn login-btn">Update Password</button>
     </div>
    </div>
    </div>
    </form>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js" integrity="sha384-FKyoEForCGlyvwx9Hj09JcYn3nv7wiPVlz7YYwJrWVcXK/BmnVDxM+D2scQbITxI" crossorigin="anonymous"></script>"
</body>
</html>